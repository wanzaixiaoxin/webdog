<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colors -->
    <Color x:Key="BgCanvas">#0f172a</Color>
    <Color x:Key="BgSurface1">#1e293b</Color>
    <Color x:Key="BgSurface2">#0b1221</Color>
    <Color x:Key="BgSurface3">#111827</Color>
    <Color x:Key="BgSurface4">#1f2937</Color>
    <Color x:Key="BgHover">rgba(148,163,184,0.08)</Color>
    <Color x:Key="BorderSubtle">#1e293b</Color>
    <Color x:Key="BorderDefault">#334155</Color>
    <Color x:Key="TextPrimary">#f8fafc</Color>
    <Color x:Key="TextSecondary">#94a3b8</Color>
    <Color x:Key="TextTertiary">#64748b</Color>
    <Color x:Key="TextDisabled">#475569</Color>
    <Color x:Key="Brand500">#0d9488</Color>
    <Color x:Key="Brand400">#2dd4bf</Color>
    <Color x:Key="BrandBg">rgba(13,148,136,0.12)</Color>
    <Color x:Key="Red400">#fb7185</Color>
    <Color x:Key="RedBg">rgba(251,113,133,0.12)</Color>
    <Color x:Key="Green400">#34d399</Color>
    <Color x:Key="GreenBg">rgba(52,211,153,0.12)</Color>
    <Color x:Key="Amber400">#fbbf24</Color>
    <Color x:Key="Blue400">#60a5fa</Color>

    <SolidColorBrush x:Key="BgCanvasBrush" Color="{StaticResource BgCanvas}"/>
    <SolidColorBrush x:Key="BgSurface1Brush" Color="{StaticResource BgSurface1}"/>
    <SolidColorBrush x:Key="BgSurface2Brush" Color="{StaticResource BgSurface2}"/>
    <SolidColorBrush x:Key="BgSurface3Brush" Color="{StaticResource BgSurface3}"/>
    <SolidColorBrush x:Key="BgSurface4Brush" Color="{StaticResource BgSurface4}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}"/>
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefault}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiary}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabled}"/>
    <SolidColorBrush x:Key="Brand500Brush" Color="{StaticResource Brand500}"/>
    <SolidColorBrush x:Key="Brand400Brush" Color="{StaticResource Brand400}"/>
    <SolidColorBrush x:Key="Red400Brush" Color="{StaticResource Red400}"/>
    <SolidColorBrush x:Key="Green400Brush" Color="{StaticResource Green400}"/>
    <SolidColorBrush x:Key="Amber400Brush" Color="{StaticResource Amber400}"/>
    <SolidColorBrush x:Key="Blue400Brush" Color="{StaticResource Blue400}"/>

    <!-- Window -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BgCanvasBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- TextBox -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BgSurface3Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="CaretBrush" Value="{StaticResource Brand400Brush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource Brand500Brush}"/>
        <Setter Property="FontFamily" Value="Consolas, Segoe UI"/>
    </Style>

    <!-- ComboBox -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource BgSurface3Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
    </Style>

    <!-- Button -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgSurface4Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- ListBox -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- ScrollViewer -->
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- TabControl -->
    <Style TargetType="TabControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
</ResourceDictionary>
