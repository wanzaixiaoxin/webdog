<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colors -->
    <Color x:Key="AppBg">#E9EEF5</Color>
    <Color x:Key="AppSurface">#F8FAFC</Color>
    <Color x:Key="AppElevated">#EEF2F7</Color>
    <Color x:Key="AppInput">#FFFFFF</Color>
    <Color x:Key="AppHover">#E6F0FF</Color>

    <Color x:Key="BorderSubtle">#CBD5E1</Color>
    <Color x:Key="BorderDefault">#94A3B8</Color>

    <Color x:Key="TextPrimary">#1F2328</Color>
    <Color x:Key="TextSecondary">#374151</Color>
    <Color x:Key="TextMuted">#475569</Color>
    <Color x:Key="TextDim">#64748B</Color>

    <Color x:Key="Accent">#0F766E</Color>
    <Color x:Key="AccentHover">#0D5F59</Color>
    <Color x:Key="AccentMuted">#CCFBF1</Color>

    <Color x:Key="Red">#B91C1C</Color>
    <Color x:Key="RedMuted">#FEE2E2</Color>
    <Color x:Key="Green">#15803D</Color>
    <Color x:Key="GreenMuted">#DCFCE7</Color>
    <Color x:Key="Amber">#B45309</Color>
    <Color x:Key="AmberMuted">#FEF3C7</Color>
    <Color x:Key="Blue">#1D4ED8</Color>
    <Color x:Key="BlueMuted">#DBEAFE</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AppBgBrush"           Color="{DynamicResource AppBg}"/>
    <SolidColorBrush x:Key="AppSurfaceBrush"      Color="{DynamicResource AppSurface}"/>
    <SolidColorBrush x:Key="AppElevatedBrush"     Color="{DynamicResource AppElevated}"/>
    <SolidColorBrush x:Key="AppInputBrush"        Color="{DynamicResource AppInput}"/>
    <SolidColorBrush x:Key="AppHoverBrush"        Color="{DynamicResource AppHover}"/>

    <SolidColorBrush x:Key="BorderSubtleBrush"    Color="{DynamicResource BorderSubtle}"/>
    <SolidColorBrush x:Key="BorderDefaultBrush"   Color="{DynamicResource BorderDefault}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="{DynamicResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="{DynamicResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush"       Color="{DynamicResource TextMuted}"/>
    <SolidColorBrush x:Key="TextDimBrush"         Color="{DynamicResource TextDim}"/>

    <SolidColorBrush x:Key="AccentBrush"          Color="{DynamicResource Accent}"/>
    <SolidColorBrush x:Key="AccentHoverBrush"     Color="{DynamicResource AccentHover}"/>
    <SolidColorBrush x:Key="AccentMutedBrush"     Color="{DynamicResource AccentMuted}"/>

    <SolidColorBrush x:Key="RedBrush"             Color="{DynamicResource Red}"/>
    <SolidColorBrush x:Key="RedMutedBrush"        Color="{DynamicResource RedMuted}"/>
    <SolidColorBrush x:Key="GreenBrush"           Color="{DynamicResource Green}"/>
    <SolidColorBrush x:Key="GreenMutedBrush"      Color="{DynamicResource GreenMuted}"/>
    <SolidColorBrush x:Key="BlueBrush"            Color="{DynamicResource Blue}"/>
    <SolidColorBrush x:Key="BlueMutedBrush"       Color="{DynamicResource BlueMuted}"/>
    <SolidColorBrush x:Key="AmberBrush"           Color="{DynamicResource Amber}"/>
    <SolidColorBrush x:Key="AmberMutedBrush"      Color="{DynamicResource AmberMuted}"/>
</ResourceDictionary>
