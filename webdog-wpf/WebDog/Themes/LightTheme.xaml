<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colors -->
    <Color x:Key="AppBg">#F0F2F5</Color>
    <Color x:Key="AppSurface">#FFFFFF</Color>
    <Color x:Key="AppElevated">#F6F8FA</Color>
    <Color x:Key="AppInput">#E8ECF0</Color>
    <Color x:Key="AppHover">#E0E4E9</Color>

    <Color x:Key="BorderSubtle">#D0D7DE</Color>
    <Color x:Key="BorderDefault">#B0B8C4</Color>

    <Color x:Key="TextPrimary">#1F2328</Color>
    <Color x:Key="TextSecondary">#656D76</Color>
    <Color x:Key="TextMuted">#8C959F</Color>
    <Color x:Key="TextDim">#B0B8C4</Color>

    <Color x:Key="Accent">#0D9488</Color>
    <Color x:Key="AccentHover">#0F766E</Color>
    <Color x:Key="AccentMuted">#CCFBF1</Color>

    <Color x:Key="Red">#DC2626</Color>
    <Color x:Key="RedMuted">#FEE2E2</Color>
    <Color x:Key="Green">#16A34A</Color>
    <Color x:Key="GreenMuted">#DCFCE7</Color>
    <Color x:Key="Amber">#D97706</Color>
    <Color x:Key="AmberMuted">#FEF3C7</Color>
    <Color x:Key="Blue">#2563EB</Color>
    <Color x:Key="BlueMuted">#DBEAFE</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AppBgBrush"           Color="{StaticResource AppBg}"/>
    <SolidColorBrush x:Key="AppSurfaceBrush"      Color="{StaticResource AppSurface}"/>
    <SolidColorBrush x:Key="AppElevatedBrush"     Color="{StaticResource AppElevated}"/>
    <SolidColorBrush x:Key="AppInputBrush"        Color="{StaticResource AppInput}"/>
    <SolidColorBrush x:Key="AppHoverBrush"        Color="{StaticResource AppHover}"/>

    <SolidColorBrush x:Key="BorderSubtleBrush"    Color="{StaticResource BorderSubtle}"/>
    <SolidColorBrush x:Key="BorderDefaultBrush"   Color="{StaticResource BorderDefault}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush"       Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="TextDimBrush"         Color="{StaticResource TextDim}"/>

    <SolidColorBrush x:Key="AccentBrush"          Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="AccentMutedBrush"     Color="{StaticResource AccentMuted}"/>

    <SolidColorBrush x:Key="RedBrush"             Color="{StaticResource Red}"/>
    <SolidColorBrush x:Key="RedMutedBrush"        Color="{StaticResource RedMuted}"/>
    <SolidColorBrush x:Key="GreenBrush"           Color="{StaticResource Green}"/>
    <SolidColorBrush x:Key="BlueBrush"            Color="{StaticResource Blue}"/>
</ResourceDictionary>
