<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DropShadowEffect x:Key="PanelShadow" BlurRadius="16" Opacity="0.55" ShadowDepth="5" Color="#000000" Direction="270"/>
    <DropShadowEffect x:Key="PanelShadowLight" BlurRadius="12" Opacity="0.25" ShadowDepth="4" Color="#000000" Direction="270"/>
    <DropShadowEffect x:Key="CardShadow" BlurRadius="8" Opacity="0.35" ShadowDepth="3" Color="#000000"/>
    <DropShadowEffect x:Key="TabShadow" BlurRadius="10" Opacity="0.4" ShadowDepth="4" Color="#000000" Direction="270"/>

</ResourceDictionary>
