<Application x:Class="WebDog.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:WebDog.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="/Themes/Shadows.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <c:BoolToGridLengthConverter x:Key="BoolToGridLength"/>
            <c:BoolToVisConverter x:Key="BoolToVis"/>
            <c:BoolToVisCollapsedConverter x:Key="BoolToVisCollapsed"/>
            <c:ProtocolColorConverter x:Key="ProtocolColorConverter"/>
            <c:MethodColorConverter x:Key="MethodColorConverter"/>
            <c:StatusColorConverter x:Key="StatusColorConverter"/>
            <c:BodyTypeColorConverter x:Key="BodyTypeColorConverter"/>
            <c:ViewToggleColorConverter x:Key="ViewToggleColorConverter"/>
            <c:WsButtonBrushConverter x:Key="WsButtonBrushConverter"/>
            <c:WsButtonStyleConverter x:Key="WsButtonStyleConverter"/>
            <c:WsButtonTextConverter x:Key="WsButtonTextConverter"/>
            <c:WsMessageBgConverter x:Key="WsMessageBgConverter"/>
            <c:WsMessageBorderConverter x:Key="WsMessageBorderConverter"/>
            <c:WsMessageFgConverter x:Key="WsMessageFgConverter"/>
            <c:StringNotEmptyToVis x:Key="StringNotEmptyToVis"/>
            <c:JsonValidationConverter x:Key="JsonValidationConverter"/>
            <c:InvertBoolConverter x:Key="InvertBoolConverter"/>
            <c:FormatSizeConverter x:Key="FormatSizeConverter"/>
            <c:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
            <c:NullToVisConverter x:Key="NullToVis"/>
            <c:ResponseViewVisConverter x:Key="ResponseViewVisConverter"/>
            <c:ResponseViewSearchVisConverter x:Key="ResponseViewSearchVisConverter"/>
            <c:JsonNodeTypeColorConverter x:Key="JsonNodeTypeColorConverter"/>
            <c:BodyTypeVisConverter x:Key="BodyTypeVisConverter"/>
            <c:FormBodyVisConverter x:Key="FormBodyVisConverter"/>
            <c:FileTypeVisConverter x:Key="FileTypeVisConverter"/>
            <c:TextTypeVisConverter x:Key="TextTypeVisConverter"/>
            <c:BinaryVisConverter x:Key="BinaryVisConverter"/>
            <c:WrapTextConverter x:Key="WrapTextConverter"/>
            <c:EqToVisConverter x:Key="EqToVis"/>
            <c:TabColorConverter x:Key="TabColorConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
