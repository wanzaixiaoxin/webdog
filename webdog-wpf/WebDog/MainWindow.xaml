<Window x:Class="WebDog.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WebDog.ViewModels"
        mc:Ignorable="d"
        Title="WebDog" Height="800" Width="1200"
        Background="#0f172a" Foreground="#f8fafc"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0b1221" BorderBrush="#1e293b" BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="WebDog" FontSize="16" FontWeight="Bold" Foreground="#2dd4bf"/>
                </StackPanel>

                <!-- Protocol Toggle -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <Border Background="#111827" CornerRadius="4" BorderBrush="#334155" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="HTTP" Padding="12,4"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{Binding Protocol, Converter={StaticResource ProtocolColorConverter}, ConverterParameter=http}"
                                    Command="{Binding SetProtocolCommand}" CommandParameter="http"/>
                            <Rectangle Width="1" Fill="#334155"/>
                            <Button Content="WS" Padding="12,4"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{Binding Protocol, Converter={StaticResource ProtocolColorConverter}, ConverterParameter=ws}"
                                    Command="{Binding SetProtocolCommand}" CommandParameter="ws"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right buttons -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Content="Env" Padding="8,4" Margin="4,0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#94a3b8"
                            Command="{Binding ToggleEnvCommand}"/>
                    <Button Content="History" Padding="8,4" Margin="4,0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#94a3b8"
                            Command="{Binding ToggleHistoryCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- URL Bar -->
        <Border Grid.Row="1" Background="#0b1221" BorderBrush="#1e293b" BorderThickness="0,0,0,1" Padding="12,10">
            <Grid>
                <!-- HTTP URL Bar -->
                <Grid Visibility="{Binding IsHttpMode, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" Width="90" SelectedValue="{Binding Method}" SelectedValuePath="Content"
                              VerticalContentAlignment="Center"
                              Background="#111827" BorderBrush="#334155" Padding="8,4">
                        <ComboBoxItem Content="GET"/>
                        <ComboBoxItem Content="POST"/>
                        <ComboBoxItem Content="PUT"/>
                        <ComboBoxItem Content="DELETE"/>
                        <ComboBoxItem Content="PATCH"/>
                        <ComboBoxItem Content="HEAD"/>
                        <ComboBoxItem Content="OPTIONS"/>
                    </ComboBox>
                    <TextBox Grid.Column="1" Margin="8,0" Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                             Background="#111827" BorderBrush="#334155" Foreground="#f8fafc"
                             VerticalContentAlignment="Center" Padding="10,6"
                             FontFamily="Consolas">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SendRequestCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="2" Content="Send" Padding="16,6"
                            Background="#0d9488" Foreground="White" BorderThickness="0"
                            Command="{Binding SendRequestCommand}"/>
                </Grid>

                <!-- WS URL Bar -->
                <Grid Visibility="{Binding IsWsMode, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" Width="70" VerticalContentAlignment="Center"
                              Background="#111827" Foreground="#2dd4bf" BorderBrush="#334155" Padding="8,4">
                        <ComboBoxItem Content="ws" IsSelected="True"/>
                        <ComboBoxItem Content="wss"/>
                    </ComboBox>
                    <TextBox Grid.Column="1" Margin="8,0" Text="{Binding WsUrl, UpdateSourceTrigger=PropertyChanged}"
                             Background="#111827" BorderBrush="#334155" Foreground="#f8fafc"
                             VerticalContentAlignment="Center" Padding="10,6"
                             FontFamily="Consolas">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding ConnectWsCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="2" Padding="16,6" BorderThickness="0"
                            Background="{Binding WsConnected, Converter={StaticResource WsButtonBrushConverter}}"
                            Foreground="White"
                            Content="{Binding WsConnected, Converter={StaticResource WsButtonTextConverter}}"
                            Command="{Binding ConnectWsCommand}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding ShowHistory, Converter={StaticResource BoolToGridLength}, ConverterParameter=260}"
                                  MinWidth="0" MaxWidth="400" x:Name="HistoryCol"/>
                <ColumnDefinition Width="{Binding ShowHistory, Converter={StaticResource BoolToGridLength}, ConverterParameter=Auto}"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="{Binding ShowEnv, Converter={StaticResource BoolToGridLength}, ConverterParameter=Auto}"/>
                <ColumnDefinition Width="{Binding ShowEnv, Converter={StaticResource BoolToGridLength}, ConverterParameter=260}"
                                  MinWidth="0" MaxWidth="400" x:Name="EnvCol"/>
            </Grid.ColumnDefinitions>

            <!-- History Sidebar -->
            <Border Grid.Column="0" Background="#0b1221" BorderBrush="#1e293b" BorderThickness="0,0,1,0"
                    Visibility="{Binding ShowHistory, Converter={StaticResource BoolToVisCollapsed}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="History" FontWeight="Bold" Padding="12,10" Foreground="#94a3b8"/>
                    <TextBox Grid.Row="1" Margin="10,0,10,8" Padding="8,4"
                             Background="#111827" BorderBrush="#334155" Foreground="#f8fafc"
                             Text="{Binding HistorySearch, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="12"/>
                    <Button Grid.Row="2" Content="Clear All" Margin="10,0,10,8" Padding="6,4"
                            Background="Transparent" BorderBrush="#334155" Foreground="#64748b" FontSize="11"
                            Command="{Binding ClearHistoryCommand}"/>
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FilteredHistory}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent" Padding="10,6" BorderBrush="#1e293b" BorderThickness="0,0,0,1"
                                            MouseLeftButtonUp="HistoryItem_Click">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                <TextBlock Text="{Binding Method}" FontSize="10" FontWeight="Bold" Padding="4,1"
                                                           Foreground="{Binding Method, Converter={StaticResource MethodColorConverter}}"/>
                                                <TextBlock Text="{Binding Status}" FontSize="10" Margin="6,0,0,0"
                                                           Foreground="{Binding Status, Converter={StaticResource StatusColorConverter}}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Row="1" Text="{Binding Url}" FontSize="11"
                                                       Foreground="#64748b" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="#1e293b" HorizontalAlignment="Stretch"
                          Visibility="{Binding ShowHistory, Converter={StaticResource BoolToVisCollapsed}}"/>

            <!-- Center Content -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HTTP Mode -->
                <Grid Visibility="{Binding IsHttpMode, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Request Panel -->
                    <Border Grid.Column="0" Background="#0f172a" BorderBrush="#1e293b" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Request Tabs -->
                            <TabControl Grid.Row="0" Background="Transparent" BorderThickness="0,0,0,1">
                                <TabItem Header="Params">
                                    <StackPanel Margin="10">
                                        <Button Content="+ Add" Padding="8,3" Margin="0,0,0,8"
                                                Background="Transparent" BorderBrush="#334155" Foreground="#64748b" FontSize="11"
                                                Command="{Binding AddParamCommand}"/>
                                        <ItemsControl ItemsSource="{Binding Params}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" Margin="0,0,4,0"
                                                                  VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="1" Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                                                 Margin="2,0" FontSize="11" Padding="4,2"
                                                                 Background="#111827" BorderBrush="#334155"/>
                                                        <TextBox Grid.Column="2" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                 Margin="2,0" FontSize="11" Padding="4,2"
                                                                 Background="#111827" BorderBrush="#334155"/>
                                                        <Button Grid.Column="3" Content="x" Padding="4,0" Margin="2,0,0,0"
                                                                Background="Transparent" BorderThickness="0" Foreground="#475569" FontSize="11"
                                                                Command="{Binding DataContext.RemoveParamCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </TabItem>
                                <TabItem Header="Headers">
                                    <StackPanel Margin="10">
                                        <Button Content="+ Add" Padding="8,3" Margin="0,0,0,8"
                                                Background="Transparent" BorderBrush="#334155" Foreground="#64748b" FontSize="11"
                                                Command="{Binding AddHeaderCommand}"/>
                                        <ItemsControl ItemsSource="{Binding Headers}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" Margin="0,0,4,0"
                                                                  VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="1" Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                                                 Margin="2,0" FontSize="11" Padding="4,2"
                                                                 Background="#111827" BorderBrush="#334155"/>
                                                        <TextBox Grid.Column="2" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                 Margin="2,0" FontSize="11" Padding="4,2"
                                                                 Background="#111827" BorderBrush="#334155"/>
                                                        <Button Grid.Column="3" Content="x" Padding="4,0" Margin="2,0,0,0"
                                                                Background="Transparent" BorderThickness="0" Foreground="#475569" FontSize="11"
                                                                Command="{Binding DataContext.RemoveHeaderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </TabItem>
                                <TabItem Header="Body">
                                    <Grid Margin="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                            <Border Background="#111827" CornerRadius="4" BorderBrush="#334155" BorderThickness="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="none" Padding="8,3" Background="Transparent" BorderThickness="0" FontSize="11"
                                                            Foreground="{Binding BodyType, Converter={StaticResource BodyTypeColorConverter}, ConverterParameter=none}"
                                                            Command="{Binding SetBodyTypeCommand}" CommandParameter="none"/>
                                                    <Button Content="JSON" Padding="8,3" Background="Transparent" BorderThickness="0" FontSize="11"
                                                            Foreground="{Binding BodyType, Converter={StaticResource BodyTypeColorConverter}, ConverterParameter=json}"
                                                            Command="{Binding SetBodyTypeCommand}" CommandParameter="json"/>
                                                    <Button Content="Text" Padding="8,3" Background="Transparent" BorderThickness="0" FontSize="11"
                                                            Foreground="{Binding BodyType, Converter={StaticResource BodyTypeColorConverter}, ConverterParameter=text}"
                                                            Command="{Binding SetBodyTypeCommand}" CommandParameter="text"/>
                                                    <Button Content="Form" Padding="8,3" Background="Transparent" BorderThickness="0" FontSize="11"
                                                            Foreground="{Binding BodyType, Converter={StaticResource BodyTypeColorConverter}, ConverterParameter=formdata}"
                                                            Command="{Binding SetBodyTypeCommand}" CommandParameter="formdata"/>
                                                    <Button Content="Raw" Padding="8,3" Background="Transparent" BorderThickness="0" FontSize="11"
                                                            Foreground="{Binding BodyType, Converter={StaticResource BodyTypeColorConverter}, ConverterParameter=raw}"
                                                            Command="{Binding SetBodyTypeCommand}" CommandParameter="raw"/>
                                                </StackPanel>
                                            </Border>
                                            <Button Content="Format" Padding="8,3" Margin="8,0,0,0"
                                                    Background="Transparent" BorderBrush="#334155" Foreground="#64748b" FontSize="11"
                                                    Command="{Binding FormatJsonCommand}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{Binding Body, Converter={StaticResource JsonValidationConverter}}"
                                                   Foreground="#fb7185" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox Grid.Row="2" Text="{Binding Body, UpdateSourceTrigger=PropertyChanged}"
                                                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas" FontSize="12" Padding="8"
                                                 Background="#111827" BorderBrush="#334155" Foreground="#f8fafc"/>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="4" Background="#1e293b" HorizontalAlignment="Stretch"/>

                    <!-- Response Panel -->
                    <Border Grid.Column="2" Background="#0f172a">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Status Bar -->
                            <Grid Grid.Row="0" Background="#0b1221" Margin="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Response.Status, FallbackValue=''}"
                                           Foreground="{Binding Response.Status, Converter={StaticResource StatusColorConverter}}"
                                           FontWeight="Bold" Padding="12,8" FontSize="13"/>
                                <TextBlock Grid.Column="1" Text="{Binding Response.StatusText, FallbackValue='Waiting...'}"
                                           Foreground="#64748b" Padding="4,8" FontSize="12"/>
                                <TextBlock Grid.Column="2" Text="{Binding Response.Time, FallbackValue='', StringFormat='{}{0}ms'}"
                                           Foreground="#94a3b8" Padding="8,8" FontSize="11"/>
                                <TextBlock Grid.Column="3" Text="{Binding Response.Size, FallbackValue='', StringFormat='{}{0}B'}"
                                           Foreground="#94a3b8" Padding="8,8" FontSize="11"/>
                            </Grid>

                            <!-- Error -->
                            <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}"
                                       Foreground="#fb7185" Padding="12,8" FontSize="12" TextWrapping="Wrap"
                                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVis}}"/>

                            <!-- Response Tabs & Content -->
                            <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">
                                <TabItem Header="Body">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,4">
                                            <Button Content="Pretty" Padding="8,3" Margin="0,0,4,0"
                                                    Background="Transparent" BorderBrush="#334155" FontSize="11"
                                                    Foreground="{Binding ResponseView, Converter={StaticResource ViewToggleColorConverter}, ConverterParameter=pretty}"
                                                    Command="{Binding SetResponseViewCommand}" CommandParameter="pretty"/>
                                            <Button Content="Raw" Padding="8,3" Margin="0,0,4,0"
                                                    Background="Transparent" BorderBrush="#334155" FontSize="11"
                                                    Foreground="{Binding ResponseView, Converter={StaticResource ViewToggleColorConverter}, ConverterParameter=raw}"
                                                    Command="{Binding SetResponseViewCommand}" CommandParameter="raw"/>
                                            <Button Content="Copy" Padding="8,3"
                                                    Background="Transparent" BorderBrush="#334155" FontSize="11"
                                                    Foreground="#94a3b8"
                                                    Command="{Binding CopyResponseCommand}"/>
                                        </StackPanel>
                                        <TextBox Grid.Row="1" IsReadOnly="True"
                                                 Text="{Binding Response.Body, FallbackValue=''}"
                                                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas" FontSize="12" Padding="10"
                                                 Background="#111827" BorderBrush="#334155" Foreground="#f8fafc"/>
                                    </Grid>
                                </TabItem>
                                <TabItem Header="Headers">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding Response.Headers}" Margin="10">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Key}" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="#7dd3fc" MinWidth="160"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="11"
                                                                   Foreground="#94a3b8" TextWrapping="Wrap"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </Border>
                </Grid>

                <!-- WS Mode -->
                <Grid Visibility="{Binding IsWsMode, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding WsMessages}" Margin="10">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,4" Padding="10,6" CornerRadius="6"
                                            Background="{Binding Type, Converter={StaticResource WsMessageBgConverter}}"
                                            BorderBrush="{Binding Type, Converter={StaticResource WsMessageBorderConverter}}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                <TextBlock Text="{Binding Type}" FontSize="10" FontWeight="Bold"
                                                           Foreground="{Binding Type, Converter={StaticResource WsMessageFgConverter}}"/>
                                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                                           FontSize="10" Margin="8,0,0,0" Foreground="#475569"/>
                                                <TextBlock Text="{Binding Size, StringFormat='{}{0}B'}"
                                                           FontSize="10" Margin="8,0,0,0" Foreground="#475569"/>
                                            </StackPanel>
                                            <TextBlock Grid.Row="1" Text="{Binding Data}" FontSize="12"
                                                       Foreground="#f8fafc" TextWrapping="Wrap" Margin="0,4,0,0"
                                                       FontFamily="Consolas"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Grid Grid.Row="1" Background="#0b1221" Margin="0,1,0,0" Padding="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding WsInput, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center" Padding="10,6"
                                 Background="#111827" BorderBrush="#334155" Foreground="#f8fafc">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SendWsMessageCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Content="Send" Padding="16,6" Margin="8,0"
                                Background="#0d9488" Foreground="White" BorderThickness="0"
                                Command="{Binding SendWsMessageCommand}"/>
                        <Button Grid.Column="2" Content="Clear" Padding="12,6"
                                Background="Transparent" BorderBrush="#334155" Foreground="#64748b"
                                Command="{Binding ClearWsMessagesCommand}"/>
                    </Grid>
                </Grid>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" Background="#1e293b" HorizontalAlignment="Stretch"
                          Visibility="{Binding ShowEnv, Converter={StaticResource BoolToVisCollapsed}}"/>

            <!-- Env Sidebar -->
            <Border Grid.Column="4" Background="#0b1221" BorderBrush="#1e293b" BorderThickness="1,0,0,0"
                    Visibility="{Binding ShowEnv, Converter={StaticResource BoolToVisCollapsed}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Environment" FontWeight="Bold" Padding="12,10" Foreground="#94a3b8"/>
                    <TextBlock Grid.Row="1" Text="Use {{variable}} in URL/headers/body" Padding="12,0,12,8"
                               Foreground="#475569" FontSize="11"/>
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EnvVars}" Margin="10,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" Margin="0,0,4,0"
                                                  VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="2,0" FontSize="11" Padding="4,2"
                                                 Background="#111827" BorderBrush="#334155" FontFamily="Consolas"/>
                                        <TextBox Grid.Column="2" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="2,0" FontSize="11" Padding="4,2"
                                                 Background="#111827" BorderBrush="#334155" FontFamily="Consolas"/>
                                        <Button Grid.Column="3" Content="x" Padding="4,0" Margin="2,0,0,0"
                                                Background="Transparent" BorderThickness="0" Foreground="#475569" FontSize="11"
                                                Command="{Binding DataContext.RemoveEnvVarCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Button Grid.Row="3" Content="+ Add Variable" Margin="10" Padding="8,4"
                            Background="Transparent" BorderBrush="#334155" BorderThickness="1" Foreground="#64748b" FontSize="11"
                            Command="{Binding AddEnvVarCommand}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
